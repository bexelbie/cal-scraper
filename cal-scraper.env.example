# Azure OpenAI translation service (optional — omit to produce Czech-only feeds)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_KEY=YOUR-API-KEY
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# CORS proxy fallback (optional — retries blocked requests through this proxy)
# CORS_PROXY_URL=https://your-proxy.example.com
