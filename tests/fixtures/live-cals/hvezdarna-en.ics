BEGIN:VEVENT
SUMMARY:A Great Adventure in a Small Solar System 3D / Velké dobrodružst
 ví v malé Sluneční soustavě 3D
DTSTART;TZID=Europe/Prague:20260508T160000
DTEND;TZID=Europe/Prague:20260508T165500
